<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="10dp">
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@mipmap/ic_launcher" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="Apk Tool"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- DECOMPILE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Декомпиляция"
                    android:textColor="@color/accent"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnPickApk"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:text="Выбрать APK из устройства"
                    android:textColor="@color/text"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline" />

                <TextView
                    android:id="@+id/lblApk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="APK не выбран"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="middle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">
                    <Button
                        android:id="@+id/btnApk2Java"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginRight="5dp"
                        android:text="apk → java"
                        android:textColor="#0E1116"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_accent" />
                    <Button
                        android:id="@+id/btnApk2Smali"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="5dp"
                        android:text="apk → smali"
                        android:textColor="#0E1116"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_accent" />
                </LinearLayout>
            </LinearLayout>

            <!-- COMPILE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Компиляция"
                    android:textColor="@color/blue"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnPickFolder"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:text="Выбрать папку (smali/java)"
                    android:textColor="@color/text"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_outline" />

                <TextView
                    android:id="@+id/lblFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Папка не выбрана"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="middle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">
                    <Button
                        android:id="@+id/btnJava2Apk"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginRight="5dp"
                        android:text="java → apk"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_blue" />
                    <Button
                        android:id="@+id/btnSmali2Apk"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="5dp"
                        android:text="smali → apk"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_blue" />
                </LinearLayout>

                <!-- SDK adaptation slider -->
                <TextView
                    android:id="@+id/lblSdk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Адаптация под Android: выкл (оригинальный SDK)"
                    android:textColor="@color/text"
                    android:textSize="13sp" />

                <SeekBar
                    android:id="@+id/seekSdk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="7"
                    android:progress="0" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 = не менять SDK · 8..14 = поднять target под версию"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- LOG BLOCK: вне внешнего ScrollView, со своей независимой прокруткой -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Логи"
                        android:textColor="@color/text"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <Button
                        android:id="@+id/btnCopy"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:minWidth="0dp"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="Копировать"
                        android:textSize="12sp"
                        android:textColor="@color/text"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_outline" />
                    <Button
                        android:id="@+id/btnClear"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginLeft="6dp"
                        android:minWidth="0dp"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="Очистить"
                        android:textSize="12sp"
                        android:textColor="@color/err"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_outline" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/lblProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:gravity="right"
                    android:textColor="@color/accent"
                    android:textSize="12sp" />

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_log"
            android:padding="10dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="false">
            <TextView
                android:id="@+id/logView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/log_text"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
